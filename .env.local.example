COMPOSE_PROJECT_NAME=ragfun-local

# Use non-conflicting host ports for your personal stack.
RUGFUNSOTA_OS_PORT=19201
RUGFUNSOTA_OS_DEBUG_PORT=19601
RUGFUNSOTA_QDRANT_HTTP=16335
RUGFUNSOTA_QDRANT_GRPC=16336
RUGFUNSOTA_PG_PORT=15434
RUGFUNSOTA_RABBIT_AMQP=25773
RUGFUNSOTA_RABBIT_HTTP=25774
RUGFUNSOTA_RABBIT_PROM=25775
RUGFUNSOTA_RETRIEVAL_PORT=18085
RUGFUNSOTA_STORAGE_PORT=18083
RUGFUNSOTA_GATE_PORT=18092
RUGFUNSOTA_AGENT_PORT=18093
RUGFUNSOTA_UI_PORT=13301
RUGFUNSOTA_PROMETHEUS_PORT=19090
RUGFUNSOTA_GRAFANA_PORT=13000

# Shared OpenAI-compatible vLLM for gate + agent-search.
# Discovered on this machine:
#   model: Qwen/Qwen3-VL-8B-Instruct
#   endpoint: http://127.0.0.1:8124/v1
# Inside containers, use host.docker.internal to reach host-published ports.
SHARED_LLM_BASE_URL=http://host.docker.internal:8124/v1
SHARED_LLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
SHARED_LLM_API_KEY=

# Keep embeddings local to your personal stack.
# infinity-embed has no published ports, so it won't collide with colleagues.
NVIDIA_DEVICE_EMBED=4
RAG_RERANK_MODE=disabled

# Optional: point doc-processor to a shared VLM endpoint too.
# Leave as-is if you want to reuse the same local shared vLLM for OCR/VLM experiments.
# Change these if your team has a separate Docling-compatible endpoint.
SHARED_VLM_BASE_URL=http://host.docker.internal:8124/v1
SHARED_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
SHARED_VLM_API_KEY=

# Start with light traffic when using a shared endpoint.
AGENT_MAX_LLM_CALLS=6
AGENT_MAX_FACT_QUERIES=1
