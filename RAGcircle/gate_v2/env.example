# ── Auth ──────────────────────────────────────────────────
AUTH_SERVER=http://localhost:8080
ADMIN_SECRET_TOKEN=your-admin-secret-token

# ── S3 / RustFS ──────────────────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=rustfs
AWS_SECRET_ACCESS_KEY=password
# AWS_SESSION_TOKEN=
S3_ENDPOINT_URL=http://localhost:9004
QUEUE_ARN=arn:rustfs:sqs:us-east-1:primary:mqtt
BUCKET_NAME=ragfun

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5438/db
MAX_PROJECTS_PER_USER=5

# ── Search ───────────────────────────────────────────────
QDRANT_URL=http://localhost:8903
OPENSEARCH_URL=http://localhost:8905

# ── Downstream services ─────────────────────────────────
RETRIEVAL_URL=http://localhost:8920
GENERATOR_URL=http://localhost:8930
